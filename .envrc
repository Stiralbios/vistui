#!/bin/bash

# Automatically sets up the devbox environment whenever you cd into this directory.

eval "$(devbox generate direnv --print-envrc)"

# Ensure the uv-managed venv bin is first in PATH if it exists.
if [ -d ".venv/bin" ]; then
    PATH="$(echo "$PATH" | tr ':' '\n' | grep -v "^.venv/bin$" | tr '\n' ':' | sed 's/:$//')"
    export PATH=".venv/bin:$PATH"
fi

# https://www.jetify.com/docs/devbox/ide-configuration/direnv
